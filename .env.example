PORT=3000

# Optional locally; the Railway template generates this automatically.
# Use 24-128 URL-safe characters.
MCP_PATH_SECRET=replace_with_a_long_random_secret

# Existing deployments can keep /mcp working while their owner reconnects ChatGPT.
# New deployments should leave this false.
MCP_LEGACY_PUBLIC_ENABLED=false

# Private connection code between the Companion Games website and this Railway deployment.
# This is not an OpenAI API key. Use a different random value from MCP_PATH_SECRET.
WEB_CONNECTION_SECRET=replace_with_another_long_random_secret

# Set true only during the migration notice period, then return it to false.
WEB_LEGACY_PUBLIC_ENABLED=false

# Optional CORS allowlist for a separate Companion Games frontend.
FRONTEND_ORIGIN=http://localhost:8888

# Optional persistent state path. Railway configures this to the attached volume.
COMPANION_GAMES_STATE_FILE=./data/graphic-adventure-state.json

# Optional override for The House That Whispers access-code SHA-256 hash.
# Store the hash only, never the plaintext Ko-fi code.
# HOUSE_OF_WHISPERS_ACCESS_CODE_HASH=

